name: CI/CD

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  release:
    types: [published]

env:
  REGISTRY: {{ registry.host }}
  IMAGE: {{ registry.image_path }}

jobs:
{% if config.test_command and config.test_command != "skip" %}
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "{{ config.node_version }}"
{% if detected.package_manager == "pnpm" %}
      - name: Install pnpm
        uses: pnpm/action-setup@v4
        with:
          version: latest
      - run: pnpm install --frozen-lockfile
{% else %}
      - run: npm ci
{% endif %}
      - run: {{ config.test_command }}

{% endif %}
  build-and-push:
{% if config.test_command and config.test_command != "skip" %}
    needs: test
{% endif %}
    if: github.event_name == 'release'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Extract semver from release tag
        id: version
        run: echo "VERSION=${GITHUB_REF_NAME#v}" >> $GITHUB_OUTPUT

      - uses: docker/setup-qemu-action@v3
      - uses: docker/setup-buildx-action@v3

      - name: Login to registry
        uses: docker/login-action@v3
        with:
          registry: {% raw %}${{ env.REGISTRY }}{% endraw %}
          username: {% raw %}${{ secrets.REGISTRY_USER }}{% endraw %}
          password: {% raw %}${{ secrets.REGISTRY_TOKEN }}{% endraw %}

      - name: Build and push
        uses: docker/build-push-action@v6
        with:
          push: true
          platforms: {{ config.build_platforms | join(",") }}
          tags: |
            {% raw %}${{ env.IMAGE }}:${{ steps.version.outputs.VERSION }}{% endraw %}
            {% raw %}${{ env.IMAGE }}:latest{% endraw %}
{% if deploy is defined and deploy.webhook_url is defined and deploy.webhook_url %}

  deploy:
    needs: build-and-push
    if: github.event_name == 'release'
    runs-on: ubuntu-latest
    steps:
      - name: Trigger deploy webhook
        run: |
          curl -X POST {% raw %}${{ secrets.DEPLOYMENT_WEBHOOK_URL }}{% endraw %} \
            -H "Content-Type: application/json" \
            -d '{"tag": "{% raw %}${{ github.ref_name }}{% endraw %}"}'
{% endif %}
